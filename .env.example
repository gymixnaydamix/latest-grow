# ===========================================
# GROW YouR NEED — Environment Configuration
# ===========================================

# --- General ---
NODE_ENV=development

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:4000/api
VITE_APP_NAME=GROW YouR NEED
VITE_OVERLAY_V2=1
VITE_PARENT_PORTAL_V2=1

# --- Backend ---
PORT=4000
API_KEY=your-api-key-here

# --- Auth ---
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRES_IN=7d

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/growyourneed?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- AI Service ---
AI_PROVIDER=mock
AI_API_KEY=your-ai-api-key-here

# --- Stripe (Parent Portal v2) ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=http://localhost:3000/parent?payment=success
STRIPE_CANCEL_URL=http://localhost:3000/parent?payment=cancel
