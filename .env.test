# ============================================
# GROW YouR NEED — Test environment config
# ============================================
# Used by vitest / jest runs. Uses in-memory or
# separate databases to avoid polluting dev data.

NODE_ENV=test

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:4000/api
VITE_APP_NAME=GROW YouR NEED (Test)

# --- Backend ---
PORT=4000
API_KEY=test-api-key

# --- Auth ---
JWT_SECRET=test-jwt-secret-not-for-production
JWT_EXPIRES_IN=1h

# --- Database (separate test DB) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/growyourneed_test?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379/1

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- AI Service ---
AI_PROVIDER=mock
AI_API_KEY=mock-key
