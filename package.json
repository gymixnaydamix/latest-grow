{
  "name": "grow-your-need",
  "version": "1.0.0",
  "private": true,
  "description": "GROW YouR NEED — All-in-one SaaS Super App for schools and individuals",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,magenta \"pnpm frontend:dev\" \"pnpm backend:dev\"",
    "build": "pnpm frontend:build && pnpm backend:build",
    "test": "pnpm frontend:test && pnpm backend:test",
    "lint": "pnpm frontend:lint && pnpm backend:lint",
    "typecheck": "tsc --noEmit && pnpm --filter ./backend typecheck",
    "frontend:dev": "vite",
    "frontend:build": "tsc --noEmit && vite build",
    "frontend:preview": "vite preview",
    "frontend:test": "jest --config jest.config.cjs --passWithNoTests",
    "frontend:lint": "eslint src/ --ext .ts,.tsx",
    "frontend:storybook": "storybook dev -p 6006",
    "backend:dev": "pnpm --filter ./backend dev",
    "backend:build": "pnpm --filter ./backend build",
    "backend:test": "pnpm --filter ./backend test",
    "backend:lint": "pnpm --filter ./backend lint",
    "backend:migrate": "pnpm --filter ./backend migrate",
    "backend:migrate:deploy": "pnpm --filter ./backend migrate:deploy",
    "backend:studio": "pnpm --filter ./backend studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.5.0"
  }
}
